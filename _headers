# Cloudflare Pages header rules. GitHub Pages hardcodes Cache-Control: max-age=600 on
# everything with no way to override it -- that's the actual cause of scores taking up to
# 10-20 minutes to show up after a refresh. `no-cache` still allows cheap ETag revalidation;
# it just stops the browser/CDN from blindly trusting a stale copy.
/data/*
  Cache-Control: no-cache
/*.html
  Cache-Control: no-cache
/src/*
  Cache-Control: no-cache
